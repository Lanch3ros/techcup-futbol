# ─────────────────────────────────────────────────────────────────────────────
# §6.5 PAGOS — ADMIN sube comprobantes; ORGANIZADOR los aprueba
# El archivo payment.jpg está en la misma carpeta api-tests/
# ─────────────────────────────────────────────────────────────────────────────

### [ADMIN] §6.5.1 — Subir comprobante de pago Equipo A (esperado: 201 Created)
POST {{host}}/payments/upload
Authorization: Bearer {{adm_token}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="teamId"

{{team_a_id}}
--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="payment.jpg"
Content-Type: image/jpeg

< ./payment.jpg
--WebAppBoundary--

> {%
  var payId = response.body.data ? response.body.data.id : null;
  if (payId) {
    client.global.set("pay_a_id", payId.toString());
    client.log("✔ pay_a_id = " + payId);
  }
%}

###

### [ADMIN] §6.5.2 — Subir comprobante de pago Equipo B (esperado: 201 Created)
POST {{host}}/payments/upload
Authorization: Bearer {{adm_token}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="teamId"

{{team_b_id}}
--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="payment.jpg"
Content-Type: image/jpeg

< ./payment.jpg
--WebAppBoundary--

> {%
  var payId = response.body.data ? response.body.data.id : null;
  if (payId) {
    client.global.set("pay_b_id", payId.toString());
    client.log("✔ pay_b_id = " + payId);
  }
%}

