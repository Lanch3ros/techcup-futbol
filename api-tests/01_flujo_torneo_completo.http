### [ADMIN] §6.2 Capture — GET /players y capturar los 14 IDs por email (1 sola llamada)
# Un único GET captura los IDs de todos los jugadores registrados arriba.
# Los IDs se guardan en variables globales player_a1_id … player_b7_id.
GET {{host}}/players
Authorization: Bearer {{adm_token}}

> {%
  var players = response.body;
  var emailMap = {
    "ja1@mail.escuelaing.edu.co": "player_a1_id",
    "ja2@mail.escuelaing.edu.co": "player_a2_id",
    "ja3@mail.escuelaing.edu.co": "player_a3_id",
    "ja4@mail.escuelaing.edu.co": "player_a4_id",
    "ja5@mail.escuelaing.edu.co": "player_a5_id",
    "ja6@mail.escuelaing.edu.co": "player_a6_id",
    "ja7@mail.escuelaing.edu.co": "player_a7_id",
    "jb1@mail.escuelaing.edu.co": "player_b1_id",
    "jb2@mail.escuelaing.edu.co": "player_b2_id",
    "jb3@mail.escuelaing.edu.co": "player_b3_id",
    "jb4@mail.escuelaing.edu.co": "player_b4_id",
    "jb5@mail.escuelaing.edu.co": "player_b5_id",
    "jb6@mail.escuelaing.edu.co": "player_b6_id",
    "jb7@mail.escuelaing.edu.co": "player_b7_id"
  };
  var found = 0;
  for (var i = 0; i < players.length; i++) {
    var email = players[i].email;
    if (emailMap.hasOwnProperty(email)) {
      client.global.set(emailMap[email], players[i].id.toString());
      client.log("✔ " + emailMap[email] + " = " + players[i].id);
      found++;
    }
  }
  client.log("IDs capturados: " + found + "/14");
%}

