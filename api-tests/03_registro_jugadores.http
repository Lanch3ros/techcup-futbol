# ─────────────────────────────────────────────────────────────────────────────
# FLUJO 4 · EVIDENCIA DE PERSISTENCIA CON LOGGING
# ─────────────────────────────────────────────────────────────────────────────

### [REG-23] Verificar perfil de STUDENT — GET /players/{id} (esperado: 200 OK)
# Confirma que name, email, userType, position, jerseyNumber y program quedaron guardados.
GET {{host}}/players/{{student_id}}
Authorization: Bearer {{adm_token}}

> {%
  var p = response.body;
  client.log("✔ STUDENT persistido:");
  client.log("  id:          " + p.id);
  client.log("  fullName:    " + p.fullName);
  client.log("  email:       " + p.email);
  client.log("  userType:    " + p.userType);
  client.log("  position:    " + p.position);
  client.log("  jerseyNumber:" + p.jerseyNumber);
  client.log("  program:     " + p.program);
%}

###

### [REG-24] Verificar perfil de CAPTAIN — GET /players/{id} (esperado: 200 OK)
# Confirma que userType=CAPITAN quedó como STUDENT con rol CAPITAN en BD.
GET {{host}}/players/{{captain_id}}
Authorization: Bearer {{adm_token}}

> {%
  var p = response.body;
  client.log("✔ CAPTAIN persistido:");
  client.log("  id:       " + p.id);
  client.log("  fullName: " + p.fullName);
  client.log("  userType: " + p.userType);
%}

###

### [REG-25] Verificar perfil de GRADUATE — GET /players/{id} (esperado: 200 OK)
# Confirma que el egresado fue creado con programa CIBERSEGURIDAD.
GET {{host}}/players/{{graduate_id}}
Authorization: Bearer {{adm_token}}

> {%
  var p = response.body;
  client.log("✔ GRADUATE persistido — program: " + p.program);
%}

###

### [REG-26] Verificar que jerseyNumber default es 10 — GET /players/{id} (esperado: 200 OK)
# REG-07 no envió jerseyNumber → el normalizador debe haberlo guardado como 10.
GET {{host}}/players/{{sindorsal_id}}
Authorization: Bearer {{adm_token}}

> {%
  var p = response.body;
  client.log("✔ jerseyNumber default verificado: " + p.jerseyNumber + " (esperado: 10)");
%}

###

### [REG-27] Verificar que position se normalizó a title-case — GET /players/{id} (esperado: 200 OK)
# REG-06 envió position="volante" en minúsculas → debe haberse guardado como "Volante".
GET {{host}}/players/{{volante_id}}
Authorization: Bearer {{adm_token}}

> {%
  var p = response.body;
  client.log("✔ position normalizada: '" + p.position + "' (esperado: 'Volante')");
%}

###

### [REG-28] Verificar jugadores disponibles — GET /players/available (esperado: 200 OK)
# Los jugadores recién registrados no tienen equipo → deben aparecer en /available.
GET {{host}}/players/available
Authorization: Bearer {{adm_token}}

> {%
  client.log("✔ Jugadores sin equipo (disponibles): " + response.body.length);
%}

###
