# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  TechCup Fútbol — Registro de Jugadores y Árbitros                     ║
# ║  Entorno: seleccionar "local" en el selector de entorno de IntelliJ    ║
# ║                                                                          ║
# ║  PREREQUISITO: API corriendo en https://localhost:8443                  ║
# ║  Tipos cubiertos: STUDENT, CAPTAIN, TEACHER, GRADUATE, RELATIVE        ║
# ║  Dominios válidos:                                                       ║
# ║    STUDENT / CAPTAIN  → @mail.escuelaing.edu.co                        ║
# ║    TEACHER / STAFF    → @escuelaing.edu.co                             ║
# ║    RELATIVE           → @gmail.com                                     ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────────────────────
# SETUP — Login para capturar tokens de administración
# ─────────────────────────────────────────────────────────────────────────────

### [SETUP] Login ADMIN
POST {{host}}/auth/login
Content-Type: application/json

{
  "email": "admin@techcup.edu.co",
  "password": "Admin123*"
}

> {%
  client.global.set("adm_token", response.body.token);
  client.log("✔ adm_token capturado");
%}

###

# ─────────────────────────────────────────────────────────────────────────────
# FLUJO 1 · BÁSICO — Registro exitoso de cada tipo de usuario
# ─────────────────────────────────────────────────────────────────────────────

### [REG-01] Registrar STUDENT (esperado: 201 Created)
# Patrón Factory Method: PlayerFactory → StudentPlayerFactory
# Email válido: @mail.escuelaing.edu.co
# Program de ingeniería: SISTEMAS
POST {{host}}/players/register
Content-Type: application/json

{
  "name": "Carlos Estudiante",
  "identification": "1000100001",
  "email": "carlos.estudiante@mail.escuelaing.edu.co",
  "password": "Techcup123*",
  "userType": "STUDENT",
  "position": "Delantero",
  "jerseyNumber": 9,
  "gender": "M",
  "age": 21,
  "semester": 6,
  "program": "SISTEMAS"
}

###

