### [REG-08] Registrar árbitro vía POST /referees (esperado: 201 Created)
# Ruta independiente: no usa Factory ni EmailValidator.
# Crea RefereeUser con role=ARBITRO y discriminador REFEREE.
POST {{host}}/referees
Content-Type: application/json

{
  "fullName": "Roberto Árbitro",
  "email": "roberto.arbitro@gmail.com",
  "password": "Techcup123*",
  "licenseNumber": "LIC-REG-001",
  "certificationLevel": "A",
  "experienceYears": 5
}

###

### [REG-09] GET /players — capturar IDs de todos los jugadores registrados
# Response handler mapea email → variable global para uso en archivos posteriores.
GET {{host}}/players
Authorization: Bearer {{adm_token}}

> {%
  var players = response.body;
  client.log("Total jugadores en BD: " + players.length);
  var emailMap = {
    "carlos.estudiante@mail.escuelaing.edu.co": "student_id",
    "ana.capitana@mail.escuelaing.edu.co":      "captain_id",
    "luis.profesor@escuelaing.edu.co":          "teacher_id",
    "sofia.egresada@mail.escuelaing.edu.co":    "graduate_id",
    "pedro.familiar@gmail.com":                 "relative_id",
    "miguel.volante@mail.escuelaing.edu.co":    "volante_id",
    "laura.sindorsal@mail.escuelaing.edu.co":   "sindorsal_id"
  };
  for (var i = 0; i < players.length; i++) {
    var email = players[i].email;
    if (emailMap.hasOwnProperty(email)) {
      client.global.set(emailMap[email], players[i].id.toString());
      client.log("✔ " + emailMap[email] + " = " + players[i].id);
    }
  }
%}

