# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  TechCup Fútbol — Gestión de Equipos                                   ║
# ║  Entorno: seleccionar "local" en el selector de entorno de IntelliJ    ║
# ║                                                                          ║
# ║  PREREQUISITO: API corriendo en https://localhost:8443                  ║
# ║  Cubre: creación de equipo, invitaciones, respuesta a invitaciones,    ║
# ║         configuración de alineación y eliminación de jugadores          ║
# ║                                                                          ║
# ║  Reglas clave:                                                           ║
# ║    RN-03-4  >50% titulares deben ser de programas de ingeniería        ║
# ║    RN-11-3  Aceptar invitación auto-rechaza las demás PENDING           ║
# ║    Máximo 12 jugadores por equipo                                       ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────────────────────
# SETUP — Registrar jugadores y capturar tokens
# 4 jugadores de ingeniería + 4 familiares (RELATIVE, sin programa)
# + 1 jugador externo para probar error de alineación
# ─────────────────────────────────────────────────────────────────────────────

### [SETUP-01] Login ADMIN
POST {{host}}/auth/login
Content-Type: application/json

{
  "email": "admin@techcup.edu.co",
  "password": "Admin123*"
}

> {%
  client.global.set("adm_token", response.body.token);
  client.log("✔ adm_token capturado");
%}

