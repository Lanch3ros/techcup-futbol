###

### [SETUP-12] GET /players — capturar IDs de los jugadores del setup
GET {{host}}/players
Authorization: Bearer {{adm_token}}

> {%
  var players = response.body;
  var emailMap = {
    "capitan.equipoa@mail.escuelaing.edu.co":    "cap_a_id",
    "jugador.sistemas@mail.escuelaing.edu.co":   "eng_01_id",
    "jugador.ciber@mail.escuelaing.edu.co":      "eng_02_id",
    "jugador.estadistica@mail.escuelaing.edu.co":"eng_03_id",
    "familiar.uno@gmail.com":                    "rel_01_id",
    "familiar.dos@gmail.com":                    "rel_02_id",
    "familiar.tres@gmail.com":                   "rel_03_id",
    "familiar.cuatro@gmail.com":                 "rel_04_id",
    "jugador.externo@mail.escuelaing.edu.co":    "ext_id"
  };
  for (var i = 0; i < players.length; i++) {
    var email = players[i].email;
    if (emailMap.hasOwnProperty(email)) {
      client.global.set(emailMap[email], players[i].id.toString());
      client.log("✔ " + emailMap[email] + " = " + players[i].id);
    }
  }
%}

