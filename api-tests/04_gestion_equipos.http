# ─────────────────────────────────────────────────────────────────────────────
# FLUJO 4 · EVIDENCIA DE PERSISTENCIA CON LOGGING
# ─────────────────────────────────────────────────────────────────────────────

### [EQ-36] GET /teams/{id} — verificar datos del equipo (esperado: 200 OK)
GET {{host}}/teams/{{team_a_id}}
Authorization: Bearer {{adm_token}}

> {%
  var t = response.body;
  client.log("✔ Equipo persistido:");
  client.log("  id:     " + t.id);
  client.log("  name:   " + t.name);
  client.log("  colors: " + t.colors);
%}

###

### [EQ-37] GET /teams/{id}/players — verificar jugadores que aceptaron (esperado: 200 OK)
# Deben aparecer: cap_a, eng_01, eng_02, eng_03, rel_01, rel_02, rel_03, multi
# NO deben aparecer: rel_04 (rechazó) ni ext (nunca fue invitado)
GET {{host}}/teams/{{team_a_id}}/players
Authorization: Bearer {{adm_token}}

> {%
  var players = response.body;
  client.log("✔ Jugadores en Equipo A: " + players.length + " (esperado: 8)");
  for (var i = 0; i < players.length; i++) {
    client.log("  - " + players[i].fullName + " (" + players[i].email + ")");
  }
%}

###

### [EQ-38] GET /teams/{id}/lineup — verificar alineación guardada (esperado: 200 OK)
# Confirma que los 7 titulares y la formación quedaron persistidos
GET {{host}}/teams/{{team_a_id}}/lineup
Authorization: Bearer {{adm_token}}

> {%
  var l = response.body.data;
  client.log("✔ Alineación persistida:");
  client.log("  formation:       " + l.formation);
  client.log("  titulares:       " + (l.startingPlayersIds ? l.startingPlayersIds.length : 0));
  client.log("  suplentes:       " + (l.reservePlayerIds ? l.reservePlayerIds.length : 0));
%}

###

### [EQ-39] GET /players/available — jugadores sin equipo (esperado: 200 OK)
# rel_04 (rechazó invitación) y ext (nunca invitado) deben aparecer aquí
GET {{host}}/players/available
Authorization: Bearer {{adm_token}}

> {%
  client.log("✔ Jugadores disponibles (sin equipo): " + response.body.length);
%}

