# ─────────────────────────────────────────────────────────────────────────────
# FLUJO 1 · BÁSICO — Crear equipo, enviar invitaciones y configurar alineación
# ─────────────────────────────────────────────────────────────────────────────

### [EQ-01] Crear Equipo A (esperado: 201 Created)
# data devuelve un String ("Equipo creado correctamente"), no el objeto — el ID se captura en EQ-02
POST {{host}}/teams
Content-Type: application/json
Authorization: Bearer {{cap_a_token}}

{
  "name": "Equipo A",
  "colors": "Azul y Blanco"
}

###

### [EQ-02] GET /teams — confirmar creación y capturar team_a_id (esperado: 200 OK)
GET {{host}}/teams
Authorization: Bearer {{adm_token}}

> {%
  var teams = response.body;
  client.log("✔ Total equipos en BD: " + teams.length);
  for (var i = 0; i < teams.length; i++) {
    if (teams[i].name === "Equipo A") {
      client.global.set("team_a_id", teams[i].id.toString());
      client.log("✔ team_a_id = " + teams[i].id);
    }
  }
%}

###

### [EQ-03] Invitar CAPITÁN al equipo (esperado: 200 OK)
POST {{host}}/teams/{{team_a_id}}/invitations
Content-Type: application/json
Authorization: Bearer {{cap_a_token}}

{
  "playerId": {{cap_a_id}}
}

