Content-Type: application/json
Authorization: Bearer {{adm_token}}

{
  "action": "REJECTED"
}

###

### [EQ-19] Configurar alineación válida — 7 titulares con >50% ingeniería (esperado: 200 OK)
# Titulares: cap_a(IA) + eng_01(SISTEMAS) + eng_02(CIBERSEGURIDAD) + eng_03(ESTADISTICA)
#            + rel_01 + rel_02 + rel_03 = 4 ingeniería / 7 = 57% ✓ (RN-03-4 OK)
# Suplente: rel_04 rechazó invitación → no está en plantilla → usamos rel_03 como suplente
# Nota: en este contexto probamos solo titulares para mantener el test simple
PUT {{host}}/teams/{{team_a_id}}/lineup
Content-Type: application/json
Authorization: Bearer {{cap_a_token}}

{
  "startingPlayersIds": [
    {{cap_a_id}},
    {{eng_01_id}},
    {{eng_02_id}},
    {{eng_03_id}},
    {{rel_01_id}},
    {{rel_02_id}},
    {{rel_03_id}}
  ],
  "formation": "4-2-1",
  "reservePlayerIds": []
}

###

