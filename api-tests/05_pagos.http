# ─────────────────────────────────────────────────────────────────────────────
# FLUJO 4 · EVIDENCIA DE PERSISTENCIA CON LOGGING
# ─────────────────────────────────────────────────────────────────────────────

### [PAY-21] Verificar estado final de pay_a — GET /payments/{id} (esperado: 200 OK)
# Confirma que el ciclo completo Pendiente → En revisión → Aprobado quedó guardado en BD
GET {{host}}/payments/{{pay_a_id}}
Authorization: Bearer {{org_token}}

> {%
  var p = response.body;
  client.log("✔ Ciclo de pago A persistido correctamente:");
  client.log("  id:          " + p.id);
  client.log("  teamId:      " + p.teamId);
  client.log("  status:      " + p.status       + " (esperado: Aprobado)");
  client.log("  approvedBy:  " + p.approvedBy);
  client.log("  uploadDate:  " + p.uploadDate);
  client.log("  reviewDate:  " + p.reviewDate);
  client.log("  receiptUrl:  " + p.receiptUrl);
%}

###

### [PAY-22] Verificar estado final de pay_b — GET /payments/{id} (esperado: 200 OK)
# Confirma que el ciclo Pendiente → En revisión → Rechazado quedó guardado con comentario
GET {{host}}/payments/{{pay_b_id}}
Authorization: Bearer {{org_token}}

> {%
  var p = response.body;
  client.log("✔ Ciclo de pago B persistido correctamente:");
  client.log("  status:   " + p.status    + " (esperado: Rechazado)");
  client.log("  comments: " + p.comments);
%}

###

### [PAY-23] Verificar todos los pagos — GET /payments (esperado: 200 OK)
# Confirma que todos los pagos creados en este archivo existen en la BD
GET {{host}}/payments
Authorization: Bearer {{org_token}}

> {%
  var payments = response.body;
  client.log("✔ Total pagos en BD: " + payments.length);
  for (var i = 0; i < payments.length; i++) {
    client.log("  [" + payments[i].id + "] teamId=" + payments[i].teamId + " status=" + payments[i].status);
  }
%}

###
