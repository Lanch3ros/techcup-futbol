# ─────────────────────────────────────────────────────────────────────────────
# FLUJO 3 · ERRORES DE VALIDACIONES DE NEGOCIO
# ─────────────────────────────────────────────────────────────────────────────

### [ARB-14] POST /referees con email ya registrado (esperado: 400 Bad Request)
# DataIntegrityViolationException (constraint unique en users.email)
# El controller catch(Exception) devuelve 400 (no 409)
POST {{host}}/referees
Content-Type: application/json
Authorization: Bearer {{adm_token}}

{
  "fullName": "Duplicado Email Test",
  "email": "carlos.arbitro@techcup.edu.co",
  "password": "Arbitro123*",
  "licenseNumber": "LIC-2026-999"
}

###

### [ARB-15] POST /referees con licenseNumber ya registrado (esperado: 400 Bad Request)
# DataIntegrityViolationException (constraint unique en users.licenseNumber)
# El controller catch(Exception) devuelve 400 (no 409)
POST {{host}}/referees
Content-Type: application/json
Authorization: Bearer {{adm_token}}

{
  "fullName": "Duplicado Licencia Test",
  "email": "duplicado.licencia@techcup.edu.co",
  "password": "Arbitro123*",
  "licenseNumber": "LIC-2026-001"
}

###

### [ARB-16] GET /referees/{id} con ID inexistente (esperado: 404 Not Found)
# El controller captura la excepción y retorna notFound().build()
GET {{host}}/referees/999999
Authorization: Bearer {{adm_token}}

###

### [ARB-17] GET /referees/{id}/matches con ID inexistente (esperado: 400 Bad Request)
# getRefereeMatches() llama a getRefereeById() que lanza ResourceNotFoundException
# El controller lo captura con catch(Exception) → badRequest().build()
GET {{host}}/referees/999999/matches
Authorization: Bearer {{adm_token}}

###

# ─────────────────────────────────────────────────────────────────────────────
# FLUJO 4 · EVIDENCIA DE PERSISTENCIA CON LOGGING
# ─────────────────────────────────────────────────────────────────────────────

### [ARB-18] Verificar perfil final del árbitro principal (esperado: 200 OK)
# Confirma que todos los campos quedaron guardados en BD
GET {{host}}/referees/{{referee_new_id}}
Authorization: Bearer {{adm_token}}

> {%
  var r = response.body;
  client.log("✔ Perfil persistido correctamente:");
  client.log("  id:                " + r.id);
  client.log("  fullName:          " + r.fullName           + " (esperado: Carlos Mendoza Árbitro)");
  client.log("  email:             " + r.email              + " (esperado: carlos.arbitro@techcup.edu.co)");
  client.log("  licenseNumber:     " + r.licenseNumber      + " (esperado: LIC-2026-001)");
  client.log("  certificationLevel:" + r.certificationLevel + " (esperado: FIFA)");
  client.log("  assignedMatchIds:  " + JSON.stringify(r.assignedMatchIds)
    + " (esperado: [" + client.global.get("match_arb_id") + "])");
%}

###

### [ARB-19] Verificar partidos asignados al árbitro (esperado: 200 OK)
# Confirma que la relación árbitro↔partido persiste tras la asignación
GET {{host}}/referees/{{referee_new_id}}/matches
Authorization: Bearer {{adm_token}}

> {%
  var matches = response.body;
  client.log("✔ Partidos asignados persistidos: " + matches.length + " (esperado: 1)");
  if (matches.length > 0) {
    client.log("  partido id:   " + matches[0].id);
    client.log("  partido field:" + matches[0].field);
    client.log("  árbitro:      " + matches[0].referee + " (esperado: Carlos Mendoza Árbitro)");
  }
%}

###

### [ARB-20] Verificar listado global de árbitros (esperado: 200 OK)
# Confirma que ambos árbitros nuevos + el del seeder existen en BD
GET {{host}}/referees
Authorization: Bearer {{adm_token}}

> {%
  var referees = response.body;
  client.log("✔ Total árbitros en BD: " + referees.length + " (mínimo 3: seeder + 2 nuevos)");
  for (var i = 0; i < referees.length; i++) {
    client.log("  [" + referees[i].id + "] "
      + referees[i].fullName
      + " — licencia: " + referees[i].licenseNumber
      + " — partidos: " + (referees[i].assignedMatchIds ? referees[i].assignedMatchIds.length : 0));
  }
%}

###
