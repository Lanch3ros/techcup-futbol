### [STATS-14] Verificar puntos de Equipo Stats A tras resultado — GET /stats/teams/{id}
# Confirma que GAP-13 actualizó correctamente las stats del equipo ganador
GET {{host}}/stats/teams/{{team_stats_a_id}}
Authorization: Bearer {{org_token}}

> {%
  var s = response.body;
  client.log("✔ Stats persistidas de Equipo Stats A:");
  client.log("  matchesPlayed: " + s.matchesPlayed + " (esperado: ≥1)");
  client.log("  matchesWon:    " + s.matchesWon    + " (esperado: ≥1)");
  client.log("  goalsFor:      " + s.goalsFor      + " (esperado: ≥2)");
  client.log("  goalsAgainst:  " + s.goalsAgainst  + " (esperado: 0)");
  client.log("  points:        " + s.points        + " (esperado: ≥3 — victoria + FairPlay si aplica)");
%}

###

### [STATS-15] Verificar tabla de posiciones final del torneo — GET /tournaments/{id}/standings
# Confirma que GAP-14 filtra correctamente los equipos inscritos
# y que el orden por puntos → diferencia de goles es correcto
GET {{host}}/tournaments/{{tournament_stats_id}}/standings
Authorization: Bearer {{org_token}}

> {%
  var standings = response.body;
  client.log("✔ Tabla de posiciones final persistida:");
  client.log("  Total equipos: " + standings.length + " (esperado: 2 — GAP-14)");
  if (standings.length >= 2) {
    client.log("  Líder:    " + standings[0].teamName
      + " pts=" + standings[0].points
      + " DG=" + standings[0].goalDifference);
    client.log("  Segundo:  " + standings[1].teamName
      + " pts=" + standings[1].points
      + " DG=" + standings[1].goalDifference);
    client.log("  Orden correcto (lider tiene más pts): "
      + (standings[0].points >= standings[1].points));
  }
%}

