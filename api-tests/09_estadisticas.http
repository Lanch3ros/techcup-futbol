GET {{host}}/stats/players/{{player_stats_a_id}}
Authorization: Bearer {{org_token}}

> {%
  var s = response.body;
  client.log("✔ Stats persistidas de Jugador Stats A:");
  client.log("  goals:        " + s.goals        + " (esperado: ≥2)");
  client.log("  yellowCards:  " + s.yellowCards   + " (esperado: 0)");
  client.log("  redCards:     " + s.redCards      + " (esperado: 0)");
  client.log("  matchesPlayed:" + s.matchesPlayed + " (esperado: ≥1)");
%}

