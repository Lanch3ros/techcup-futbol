### [SETUP-07] GET /teams — capturar IDs de los equipos de stats
GET {{host}}/teams
Authorization: Bearer {{adm_token}}

> {%
  var teams = response.body;
  for (var i = 0; i < teams.length; i++) {
    if (teams[i].name === "Equipo Stats A") {
      client.global.set("team_stats_a_id", teams[i].id.toString());
      client.log("✔ team_stats_a_id = " + teams[i].id);
    }
    if (teams[i].name === "Equipo Stats B") {
      client.global.set("team_stats_b_id", teams[i].id.toString());
      client.log("✔ team_stats_b_id = " + teams[i].id);
    }
  }
%}

###

### [SETUP-08] GET /players — capturar IDs de los jugadores de stats
GET {{host}}/players
Authorization: Bearer {{adm_token}}

> {%
  var players = response.body;
  for (var i = 0; i < players.length; i++) {
    if (players[i].email === "jugador.stats.a@mail.escuelaing.edu.co") {
      client.global.set("player_stats_a_id", players[i].id.toString());
      client.log("✔ player_stats_a_id = " + players[i].id);
    }
    if (players[i].email === "jugador.stats.b@mail.escuelaing.edu.co") {
      client.global.set("player_stats_b_id", players[i].id.toString());
      client.log("✔ player_stats_b_id = " + players[i].id);
    }
  }
%}

