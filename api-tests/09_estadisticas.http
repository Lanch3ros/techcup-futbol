# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  TechCup Fútbol — Estadísticas                                         ║
# ║  Entorno: seleccionar "local" en el selector de entorno de IntelliJ    ║
# ║                                                                          ║
# ║  PREREQUISITO: API corriendo en https://localhost:8443                  ║
# ║                                                                          ║
# ║  Endpoints (todos GET — sin wrapper GenericResponse):                   ║
# ║    GET /stats/top-scorers           → List<PlayerStats>                ║
# ║    GET /stats/tournaments/{id}/top-scorers → List<PlayerStats>         ║
# ║    GET /stats/players/{id}          → PlayerStats                      ║
# ║    GET /stats/teams/{id}            → StandingDTO                      ║
# ║    GET /tournaments/{id}/standings  → List<StandingDTO>                ║
# ║                                                                          ║
# ║  PlayerStats: playerId, playerName, teamName, goals,                   ║
# ║               yellowCards, redCards, matchesPlayed                     ║
# ║                                                                          ║
# ║  StandingDTO: teamId, teamName, matchesPlayed, matchesWon,             ║
# ║               matchesDrawn, matchesLost, goalsFor, goalsAgainst,       ║
# ║               goalDifference, points (incluye FairPlay RN-09-2)        ║
# ║                                                                          ║
# ║  Reglas:                                                                ║
# ║    GAP-14: standings solo incluye equipos inscritos en el torneo       ║
# ║    GAP-15: top-scorers por torneo solo cuenta eventos de sus partidos  ║
# ║    GAP-16: matchesPlayed = partidos Finalizado con ≥1 evento           ║
# ║    RN-09-2: +1 FairPlay por partido Finalizado sin tarjetas del equipo ║
# ║                                                                          ║
# ║  NOTA sobre top-scorers por torneo: GET /stats/tournaments/{id}/...    ║
# ║  solo cuenta eventos de partidos con tournament_id = {id} en BD.       ║
# ║  Los partidos creados con POST /matches (sin generate-matches) no       ║
# ║  quedan asociados al torneo → endpoint devuelve lista vacía.           ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────────────────────
# SETUP — Tokens + jugadores + equipos + pagos + torneo + partido completo
# ─────────────────────────────────────────────────────────────────────────────

### [SETUP-01] Login ORGANIZADOR
POST {{host}}/auth/login
Content-Type: application/json

{
  "email": "organizador@techcup.edu.co",
  "password": "Admin123*"
}

> {%
  client.global.set("org_token", response.body.token);
  client.log("✔ org_token capturado");
%}

###

### [SETUP-02] Login ADMIN
POST {{host}}/auth/login
Content-Type: application/json

{
  "email": "admin@techcup.edu.co",
  "password": "Admin123*"
}

> {%
  client.global.set("adm_token", response.body.token);
  client.log("✔ adm_token capturado");
%}

