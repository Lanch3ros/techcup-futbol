# ─────────────────────────────────────────────────────────────────────────────
# FLUJO 1 · BÁSICO — Consulta de todas las estadísticas
# ─────────────────────────────────────────────────────────────────────────────

### [STATS-01] GET /stats/top-scorers — goleadores globales (esperado: 200 OK)
# Devuelve List<PlayerStats> — incluye a Jugador Stats A con ≥2 goles
# Puede incluir goles de otras sesiones de prueba registrados en BD
GET {{host}}/stats/top-scorers
Authorization: Bearer {{org_token}}

> {%
  var scorers = response.body;
  client.log("✔ Goleadores globales: " + scorers.length + " jugadores");
  for (var i = 0; i < scorers.length; i++) {
    client.log("  " + (i+1) + ". " + scorers[i].playerName
      + " — GOL=" + scorers[i].goals
      + " AM=" + scorers[i].yellowCards
      + " RJ=" + scorers[i].redCards
      + " PJ=" + scorers[i].matchesPlayed);
  }
%}

###

### [STATS-02] GET /stats/tournaments/{id}/top-scorers — goleadores del torneo (esperado: 200 OK)
# GAP-15: filtra solo eventos de partidos con tournament_id={id} en BD
# El partido del SETUP fue creado con POST /matches (no generate-matches)
# → no tiene tournament_id seteado → lista vacía (comportamiento esperado y correcto)
GET {{host}}/stats/tournaments/{{tournament_stats_id}}/top-scorers
Authorization: Bearer {{org_token}}

> {%
  var scorers = response.body;
  client.log("✔ Goleadores del torneo " + client.global.get("tournament_stats_id")
    + ": " + scorers.length + " jugadores");
  client.log("  (vacío porque POST /matches no asocia el partido al torneo)");
%}

###

### [STATS-03] GET /stats/players/{id} — stats de Jugador Stats A (esperado: 200 OK)
# GAP-16: matchesPlayed = partidos "Finalizado" donde el jugador tuvo ≥1 evento
# Jugador Stats A: 2 GOL en partido FINALIZADO → goals=2, matchesPlayed=1
GET {{host}}/stats/players/{{player_stats_a_id}}
Authorization: Bearer {{org_token}}

> {%
  var s = response.body;
  client.log("✔ Stats Jugador Stats A:");
  client.log("  playerId:     " + s.playerId);
  client.log("  playerName:   " + s.playerName);
  client.log("  goals:        " + s.goals        + " (esperado: ≥2)");
  client.log("  yellowCards:  " + s.yellowCards   + " (esperado: 0)");
  client.log("  redCards:     " + s.redCards      + " (esperado: 0)");
  client.log("  matchesPlayed:" + s.matchesPlayed + " (esperado: ≥1)");
  client.log("  teamName:     " + s.teamName);
%}

###

### [STATS-04] GET /stats/players/{id} — stats de Jugador Stats B (esperado: 200 OK)
# Jugador Stats B: AMARILLA + ROJA en partido FINALIZADO → yellowCards=1, redCards=1, matchesPlayed=1
GET {{host}}/stats/players/{{player_stats_b_id}}
Authorization: Bearer {{org_token}}

> {%
  var s = response.body;
  client.log("✔ Stats Jugador Stats B:");
  client.log("  goals:        " + s.goals        + " (esperado: 0)");
  client.log("  yellowCards:  " + s.yellowCards   + " (esperado: ≥1)");
  client.log("  redCards:     " + s.redCards      + " (esperado: ≥1)");
  client.log("  matchesPlayed:" + s.matchesPlayed + " (esperado: ≥1)");
%}

###

### [STATS-05] GET /stats/teams/{id} — stats Equipo Stats A (esperado: 200 OK)
# GAP-13: registerResult() actualizó: matchesPlayed=1, matchesWon=1, points=3, goalsFor=2
# RN-09-2: FairPlay +1 si el equipo no tuvo tarjetas en partidos finalizados
#           (players sin teamId asignado → sus tarjetas no cuentan para ningún equipo)
# → Equipo Stats A: points=3 (victoria) + 1 (FairPlay, sin tarjetas) = 4
GET {{host}}/stats/teams/{{team_stats_a_id}}
Authorization: Bearer {{org_token}}

> {%
  var s = response.body;
  client.log("✔ Stats Equipo Stats A (ganó 2-0):");
  client.log("  teamName:      " + s.teamName);
  client.log("  matchesPlayed: " + s.matchesPlayed + " (esperado: ≥1)");
  client.log("  matchesWon:    " + s.matchesWon    + " (esperado: ≥1)");
  client.log("  matchesDrawn:  " + s.matchesDrawn);
  client.log("  matchesLost:   " + s.matchesLost);
  client.log("  goalsFor:      " + s.goalsFor      + " (esperado: ≥2)");
  client.log("  goalsAgainst:  " + s.goalsAgainst  + " (esperado: 0)");
  client.log("  goalDifference:" + s.goalDifference + " (esperado: ≥2)");
  client.log("  points:        " + s.points        + " (esperado: ≥3, incluye FairPlay)");
%}

###

### [STATS-06] GET /stats/teams/{id} — stats Equipo Stats B (esperado: 200 OK)
# GAP-13: matchesPlayed=1, matchesLost=1, points=0, goalsFor=0, goalsAgainst=2
# RN-09-2: +1 FairPlay si el equipo no tuvo tarjetas
#           (player_stats_b sin teamId → tarjetas no cuentan para equipo B → +1 FairPlay)
# → Equipo Stats B: points=0 + 1 (FairPlay) = 1
GET {{host}}/stats/teams/{{team_stats_b_id}}
Authorization: Bearer {{org_token}}

> {%
  var s = response.body;
  client.log("✔ Stats Equipo Stats B (perdió 0-2):");
  client.log("  matchesPlayed: " + s.matchesPlayed + " (esperado: ≥1)");
  client.log("  matchesWon:    " + s.matchesWon    + " (esperado: 0)");
  client.log("  matchesLost:   " + s.matchesLost   + " (esperado: ≥1)");
  client.log("  goalsFor:      " + s.goalsFor      + " (esperado: 0)");
  client.log("  goalsAgainst:  " + s.goalsAgainst  + " (esperado: ≥2)");
  client.log("  goalDifference:" + s.goalDifference + " (esperado: ≤-2)");
  client.log("  points:        " + s.points        + " (esperado: ≥0, incluye FairPlay)");
%}

###

### [STATS-07] GET /tournaments/{id}/standings — tabla de posiciones (esperado: 200 OK)
# GAP-14: solo equipos inscritos en el torneo (Equipo Stats A y B)
# Orden: puntos → diferencia de goles → goles anotados
# Devuelve List<StandingDTO> directamente (sin wrapper — en TournamentController)
GET {{host}}/tournaments/{{tournament_stats_id}}/standings
Authorization: Bearer {{org_token}}

> {%
  var standings = response.body;
  client.log("✔ Tabla de posiciones del torneo " + client.global.get("tournament_stats_id")
    + ": " + standings.length + " equipos (esperado: 2)");
  for (var i = 0; i < standings.length; i++) {
    var s = standings[i];
    client.log("  " + (i+1) + ". " + s.teamName
      + " | pts=" + s.points
      + " PJ=" + s.matchesPlayed
      + " PG=" + s.matchesWon
      + " PP=" + s.matchesLost
      + " GF=" + s.goalsFor
      + " GC=" + s.goalsAgainst
      + " DG=" + s.goalDifference);
  }
%}

###

# ─────────────────────────────────────────────────────────────────────────────
# FLUJO 2 · ERRORES DE VALIDACIONES DE NEGOCIO
# (Todos son GETs — no hay validación de input; errores son por ID inexistente)
# ─────────────────────────────────────────────────────────────────────────────

### [STATS-08] GET /stats/players/999999 — jugador inexistente (esperado: 404 Not Found)
# statsService.getPlayerStats() lanza ResourceNotFoundException → controller → notFound()
GET {{host}}/stats/players/999999
Authorization: Bearer {{org_token}}

###

### [STATS-09] GET /stats/teams/999999 — equipo inexistente (esperado: 404 Not Found)
# statsService.getTeamStats() lanza ResourceNotFoundException → controller → notFound()
GET {{host}}/stats/teams/999999
Authorization: Bearer {{org_token}}

###

### [STATS-10] GET /stats/tournaments/999999/top-scorers — torneo inexistente (esperado: 200 OK con lista vacía)
# IMPORTANTE: getTopScorersByTournament() usa orElse(null) y devuelve lista vacía (no lanza excepción)
# → el controller devuelve 200 OK con [] — no es un 404
GET {{host}}/stats/tournaments/999999/top-scorers
Authorization: Bearer {{org_token}}

> {%
  client.log("✔ Goleadores torneo inexistente: " + response.body.length
    + " (esperado: 0 — no lanza 404)");
%}

###

### [STATS-11] GET /tournaments/999999/standings — torneo inexistente (esperado: 400 Bad Request)
# getTournamentStandings() lanza ResourceNotFoundException
# TournamentController captura con catch(Exception) → badRequest().build()
GET {{host}}/tournaments/999999/standings
Authorization: Bearer {{org_token}}

###

# ─────────────────────────────────────────────────────────────────────────────
# FLUJO 3 · EVIDENCIA DE PERSISTENCIA CON LOGGING
# ─────────────────────────────────────────────────────────────────────────────

### [STATS-12] Verificar que Jugador Stats A aparece en top-scorers globales (esperado: 200 OK)
# Confirma que los GOL del SETUP fueron persistidos y el motor los computa
GET {{host}}/stats/top-scorers
Authorization: Bearer {{org_token}}

> {%
  var scorers = response.body;
  var found = false;
  for (var i = 0; i < scorers.length; i++) {
    if (scorers[i].playerName === "Jugador Stats A") {
      found = true;
      client.log("✔ Jugador Stats A en top-scorers globales:");
      client.log("  posición:    " + (i+1));
      client.log("  goals:       " + scorers[i].goals + " (esperado: ≥2)");
      client.log("  matchesPlayed:" + scorers[i].matchesPlayed);
    }
  }
  if (!found) client.log("✗ Jugador Stats A NO encontrado en top-scorers");
%}

###

