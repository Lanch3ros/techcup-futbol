###

### [SETUP-16] GET /tournaments — capturar tournament_stats_id
GET {{host}}/tournaments
Authorization: Bearer {{org_token}}

> {%
  var tournaments = response.body;
  for (var i = 0; i < tournaments.length; i++) {
    if (tournaments[i].regulations
        && tournaments[i].regulations.indexOf("estadísticas Sprint 5") !== -1) {
      client.global.set("tournament_stats_id", tournaments[i].id.toString());
      client.log("✔ tournament_stats_id = " + tournaments[i].id);
    }
  }
%}

